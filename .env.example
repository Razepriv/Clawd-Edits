# Copy to .env and fill in your own keys. .env is gitignored.

# ElevenLabs (music + SFX)
ELEVENLABS_API_KEY=

# Google Gemini / Veo 3
GOOGLE_API_KEY=

# Obsidian Local REST API plugin
# 1. Install plugin in Obsidian, enable HTTPS.
# 2. Copy the generated API key from plugin settings.
# 3. Plugin listens on 127.0.0.1:27124 by default.
OBSIDIAN_API_KEY=
OBSIDIAN_BASE_URL=https://127.0.0.1:27124

# Optional — alternative B-roll generators
# FAL_KEY=
# RUNWAY_API_KEY=
